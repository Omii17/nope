3rd  Embedded C program for LCD interfacing with PIC18F4550 microcontroller..
#include <pic18f4550.h>

#define LCD_EN LATAbits.LA1
#define LCD_RS LATAbits.LA0
#define LCDPORT LATB

void lcd_delay(unsigned int time)
{
    unsigned int i, j;
    for(i = 0; i < time; i++)
        for(j = 0; j < 100; j++);
}

void LCD_Command(unsigned char cmd)
{
    LCD_RS = 0;
    LCDPORT = cmd;
    LCD_EN = 1;
    lcd_delay(5);
    LCD_EN = 0;
    lcd_delay(5);
}

void LCD_Data(unsigned char data)
{
    LCD_RS = 1;
    LCDPORT = data;
    LCD_EN = 1;
    lcd_delay(5);
    LCD_EN = 0;
    lcd_delay(5);
}

void LCD_Init()
{
    ADCON1 = 0x0F;
    TRISB = 0x00;
    TRISAbits.RA0 = 0;
    TRISAbits.RA1 = 0;

    LCD_Command(0x38);
    LCD_Command(0x06);
    LCD_Command(0x0C);
    LCD_Command(0x01);
    LCD_Command(0x80);
}

void LCD_String(char *str)
{
    while(*str)
    {
        LCD_Data(*str++);
    }
}

void main(void)
{
    LCD_Init();

    LCD_String("MicroEmbedded");

    LCD_Command(0xC0);   // Move to 2nd line

    LCD_String("PIC-18F Board");

    while(1);
}


4th Generation of PWM signal for DC motor control with PIC microcontroller.
#include <xc.h>
#include <pic18f4550.h>

void delay(unsigned int time)
{
    unsigned int i, j;
    for(i = 0; i < time; i++)
        for(j = 0; j < 1000; j++);
}

void PWM_Init()
{
    TRISCbits.TRISC2 = 0;   // CCP1 pin as output

    PR2 = 149;              // PWM Period
    T2CON = 0b00000110;     // Timer2 ON, Prescaler = 16

    CCP1CON = 0b00001100;   // PWM mode
    CCPR1L = 15;            // Initial duty cycle (~10%)
}

void main(void)
{
    unsigned int i;

    PWM_Init();

    while(1)
    {
        // Increase duty cycle
        for(i = 15; i < 150; i++)
        {
            CCPR1L = i;
            delay(100);
        }

        // Decrease duty cycle
        for(i = 150; i > 15; i--)
        {
            CCPR1L = i;
            delay(100);
        }
    }
}

5th 05:To interface LEDs with a PIC microcontroller and implement a direction-controlled LED
chaser by programming the controller.
#include <pic18f458.h>

void delay()
{
    unsigned int i;
    for(i = 0; i < 30000; i++);
}

void main()
{
    unsigned char key = 0, i;

    TRISB = 0x00;    
    LATB  = 0x00;

    ADCON1 = 0x07;    

    TRISAbits.TRISA2 = 1;   
    TRISAbits.TRISA3 = 1;   

    while(1)
    {
       
        if(PORTAbits.RA2 == 0)
            key = 0;
        else if(PORTAbits.RA3 == 0)
            key = 1;

        if(key == 0)
        {
            for(i = 0; i < 8; i++)
            {
                LATB = (1 << i);
                delay();
                LATB = 0x00;
            }
        }

        else if(key == 1)
        {
            for(i = 7; i >= 0; i--)
            {
                LATB = (1 << i);
                delay();
                LATB = 0x00;
            }
        }
    }
}

8th To Interfacing IR sensor with Arduino for an application to detect obstacle and notify
users using LED.
const int IR_PIN  = 2;
const int LED_PIN = 13;

void setup()
{
    pinMode(IR_PIN, INPUT);
    pinMode(LED_PIN, OUTPUT);
}

void loop()
{
    if (digitalRead(IR_PIN) == LOW)
    {
        digitalWrite(LED_PIN, HIGH);   // Object detected
    }
    else
    {
        digitalWrite(LED_PIN, LOW);    // No object
    }
}

9th Interfacing Ultrasonic sensor with Arduino for an application to find out the distance
between obstacles.
void setup() {
  pinMode(9, OUTPUT);
  pinMode(10, INPUT);
  Serial.begin(9600);
}

void loop() {
  digitalWrite(9, LOW); 
  delayMicroseconds(2);
  digitalWrite(9, HIGH); 
  delayMicroseconds(10);
  digitalWrite(9, LOW);

  float d = pulseIn(10, HIGH) * 0.017;

  Serial.println(d);

  delay(500);
}

1oth To interface a temperature and humidity sensor with an ARM LPC microcontroller
and measure environmental temperature and humidity.

#include <lpc214x.h>
#include <stdio.h>

#define DHT (1<<18)

void d(int x){ for(int i=0;i<x;i++) for(int j=0;j<6000;j++); }
void u(int x){ for(int i=0;i<x;i++) for(int j=0;j<7;j++); }

void tx(char c){ U0THR=c; while(!(U0LSR&0x40)); }
void print(char *s){ while(*s) tx(*s++); }

unsigned char read(){
  unsigned char i,d=0;
  for(i=0;i<8;i++){
    while(!(IO1PIN&DHT));
    u(30);
    d=(d<<1)|((IO1PIN&DHT)?1:0);
    while(IO1PIN&DHT);
  }
  return d;
}

int main(){
  char b[20];
  unsigned char h1,h2,t1,t2,c;

  PINSEL0|=0x05;
  U0LCR=0x83;
  int dv=(15000000/16)/9600;
  U0DLL=dv%256; U0DLM=dv/256;
  U0LCR=0x03;

  print("DHT11\r\n");

  while(1){
    IO1DIR|=DHT; IO1CLR=DHT; d(20); IO1SET=DHT;
    IO1DIR&=~DHT;
    while(IO1PIN&DHT); while(!(IO1PIN&DHT)); while(IO1PIN&DHT);

    h1=read(); h2=read(); t1=read(); t2=read(); c=read();

    if((h1+h2+t1+t2)!=c) print("Err\r\n");
    else{
      sprintf(b,"H:%d.%d T:%d.%d\r\n",h1,h2,t1,t2);
      print(b);
    }

    d(5000);
  }
}

